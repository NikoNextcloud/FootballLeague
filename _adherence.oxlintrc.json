{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/data/**",
              "components/feedback/**",
              "components/navigation/**",
              "ui_kits/a-grupa/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Inter))/i]",
        "message": "Font not provided by the design system. Available: Inter."
      },
      {
        "selector": "JSXOpeningElement[name.name='BottomNav'] > JSXAttribute > JSXIdentifier[name!=/^(?:activePath|onNavigate|key|ref|className|style|children)$/]",
        "message": "<BottomNav> doesn't accept that prop. Declared props: activePath, onNavigate."
      },
      {
        "selector": "JSXOpeningElement[name.name='Chip'] > JSXAttribute > JSXIdentifier[name!=/^(?:active|children|onClick|key|ref|className|style|children)$/]",
        "message": "<Chip> doesn't accept that prop. Declared props: active, children, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='EmptyState'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|key|ref|className|style|children)$/]",
        "message": "<EmptyState> doesn't accept that prop. Declared props: children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Header'] > JSXAttribute > JSXIdentifier[name!=/^(?:activePath|onNavigate|notifySlot|logoSrc|key|ref|className|style|children)$/]",
        "message": "<Header> doesn't accept that prop. Declared props: activePath, onNavigate, notifySlot, logoSrc."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|on|disabled|onClick|title|key|ref|className|style|children)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: children, on, disabled, onClick, title."
      },
      {
        "selector": "JSXOpeningElement[name.name='EventItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:strHomeTeam|strAwayTeam|intHomeScore|intAwayScore|dateEvent|strTime|strStatus|strHomeTeamBadge|strAwayTeamBadge|strVenue|intRound|key|ref|className|style|children)$/]",
        "message": "<EventItem> doesn't accept that prop. Declared props: strHomeTeam, strAwayTeam, intHomeScore, intAwayScore, dateEvent, strTime, strStatus, strHomeTeamBadge, strAwayTeamBadge, strVenue, intRound."
      },
      {
        "selector": "JSXOpeningElement[name.name='ScorerRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:rank|player|team|teamBadge|goals|key|ref|className|style|children)$/]",
        "message": "<ScorerRow> doesn't accept that prop. Declared props: rank, player, team, teamBadge, goals."
      },
      {
        "selector": "JSXOpeningElement[name.name='Select'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|onChange|children|key|ref|className|style|children)$/]",
        "message": "<Select> doesn't accept that prop. Declared props: value, onChange, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='TableRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:idTeam|strTeam|strBadge|intRank|intPlayed|intWin|intDraw|intLoss|intGoalsFor|intGoalsAgainst|intGoalDifference|intPoints|strForm|key|ref|className|style|children)$/]",
        "message": "<TableRow> doesn't accept that prop. Declared props: idTeam, strTeam, strBadge, intRank, intPlayed, intWin, intDraw, intLoss, intGoalsFor, intGoalsAgainst, intGoalDifference, intPoints, strForm."
      },
      {
        "selector": "JSXOpeningElement[name.name='Stat'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|key|ref|className|style|children)$/]",
        "message": "<Stat> doesn't accept that prop. Declared props: value, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='TeamBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:src|name|size|key|ref|className|style|children)$/]",
        "message": "<TeamBadge> doesn't accept that prop. Declared props: src, name, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='TeamCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|badgeSrc|onClick|key|ref|className|style|children)$/]",
        "message": "<TeamCard> doesn't accept that prop. Declared props: name, badgeSrc, onClick."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
    "components": {
      "BottomNav": {
        "replaces": []
      },
      "Chip": {
        "replaces": []
